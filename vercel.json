{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)\.(jpg|jpeg|png|gif|svg|ico|webp|avif|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/listings", "destination": "/east-bay/entry", "permanent": false },
    { "source": "/east-bay", "destination": "/east-bay/entry", "permanent": false },
    { "source": "/south-bay", "destination": "/south-bay/entry", "permanent": false },
    { "source": "/north-bay", "destination": "/north-bay/entry", "permanent": false }
  ]
}

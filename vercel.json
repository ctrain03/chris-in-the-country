{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/listings", "destination": "/east-bay/entry", "permanent": false },
    { "source": "/east-bay", "destination": "/east-bay/entry", "permanent": false },
    { "source": "/south-bay", "destination": "/south-bay/entry", "permanent": false },
    { "source": "/north-bay", "destination": "/north-bay/entry", "permanent": false }
  ]
}
